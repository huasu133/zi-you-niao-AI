{
  "name": "ziyouniao",
  "version": "4.0.0",
  "description": "自由鸟 - 自托管 AI 助手",
  "main": "electron-main.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "electron-start": "electron .",
    "pack": "electron-builder --win"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.0",
    "sql.js": "^1.14.1"
  },
  "optionalDependencies": {
    "@contextwire/sdk": "^1.0.0",
    "@tavily/core": "^1.0.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ziyouniao.app",
    "productName": "自由鸟",
    "files": [
      "app.js",
      "electron-main.js",
      "mcp-client.js",
      "tool-registry.js",
      "expert-router.js",
      "soul.md",
      "tools/**/*",
      "connectors/**/*",
      "experts/**/*",
      "public/**/*",
      "package.json",
      "ziyouniao-icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "ziyouniao-icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
